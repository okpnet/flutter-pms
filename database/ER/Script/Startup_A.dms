//生成クラス
class GeneratManager{
    IsSchema ="";

    entityArray=new Array;//テーブルセット
    relArray=new Array;//リレーションシップセット
    viewArray=new Array;//ビューセット
    hierarchyArray=new Array;//hierarchyテーブルセット
	//コンストラクタ
    function GeneratManager(doc,schema){
        IsSchema=schema;
        
        var len=0;
        var entsLen=0;
        var ents=new Array;
        var rels=new Array;
        
        var prg=new Progress("ER objects",10,ext.count(doc.objects));
        ext.enumrable(doc.objects,function(e,progress){
            prg.up();
            if(e.objectType=="Entity"){
                ents.add(e);
                entsLen++;
            }else if(e.objectType=="Relation" || e.objectType=="View"){
                rels.add(e);
            }
        });

        
        //リレーションシップセット
        relArray=rels;
        
        //テーブルセット
        prg=new Progress("Entity",10,ext.count(ents));
        ext.enumrable(ents,function(e,progress){
            prg.up();
            entityArray.add(new Entity(e,relArray));
        });
        
		
        //hierarchyテーブルセット
        
        var hierarchyEntities=ext.toWhere(ents,function(e){//hierarchyテーブルズ
            var reg=new RegExp("^hrchy_");
            return reg.test(e.pName);
        });
        prg=new Progress("Hierarchy",10,ext.count(hierarchyEntities));
        ext.enumrable(hierarchyEntities,function(e,progress){
            prg.up();
            var rels=ext.toWhere(relArray,function(t){//祖先と子孫の2つのリレーションシップを取得
                return t.entityPName2==e.pName;
            });
            
            if(ext.count(rels)!=2){
                println(" Hierarchical "+e.pName+" entity requires 2 relationships, but only "+ext.count(rels)+" relationship was given.");
                return;
            }
            
            var ent=ext.toFirst(ents,function(e)
                {
                    return rels[0].entityPName1==e.pName;//リレーション先のエンティティを取得
                });
            
            if(ent==null){
                println("hierarchy "+e.pName+" relation ship entity "+ rels[0].entityPName1 +" not found inentity array.");
                return;
            }
            
            hierarchyArray.add(new Hierarchy(ent,e,rels));
        });

    }
    
	function CreateDeleteAll(){
		var query="";
        for(var index in entityArray){
			query+=entityArray[index].GetDeleteQuery(IsSchema);
        }
        NewPage(query);
        return query;
	}
    //  全エンティティのクエリ生成
    //dropFlg ドロップクエリを先頭に追加する
    function CreateAll(dropFlg,preffix,suffix){
        var counter=0;
        var max=0;
        var query=preffix+CR;

        max=ext.count(entityArray);
        var prg=new Progress("Drop",10,max);
        if(dropFlg){
            query +="--" +max+ ".drop tables"+CR;
            ext.enumrable(entityArray,function(e,progress){
                prg.up();
                query+=e.GetDropQuery(IsSchema);
            });
        }
        var tables=ext.toWhere(entityArray,function(e){return !e.IsView;});
        
        max=ext.count(tables);
        query +="--" +max+ ".create tables"+CR;
        prg=new Progress("Table",10,max);
        ext.enumrable(tables,function(e,progress){
            prg.up();
            query+=e.GetQuery(IsSchema);
        });


        query +="--" +max+ ".add table comments"+CR;
        prg=new Progress("Comment",10,max);
        ext.enumrable(tables,function(e,progress){
            prg.up();
            query+=e.GetCommentQuery(IsSchema);
        });

        query +="--" +max+ ".add table primary key and index"+CR;
        prg=new Progress("primary key",10,max);
        ext.enumrable(tables,function(e,progress){
            prg.up();
            query+=e.GetPkQuery(IsSchema);
            query+=e.GetUniqueQuery(IsSchema);
        });

        query +="--" +max+ ".add table foreign key"+CR;
        prg=new Progress("foreign key",10,max);
        ext.enumrable(tables,function(e,progress){
            prg.up();
            query+=e.GetFkQuery(IsSchema,entityArray);
        });

        query +="--" +max+ ".add table trigger"+CR;
        prg=new Progress("trigger",10,max);
        ext.enumrable(tables,function(e,progress){
            prg.up();
            if(dropFlg)query+=e.IsTrigger.GetDropQuery(IsSchema);
            query+=e.GetTriggerQuery(IsSchema,entityArray);
        });
        
        max=ext.count(hierarchyArray);
        query +="--" +max+ ".add hierarchy trigger"+CR;
        prg=new Progress("hierarchy",10,max);
        ext.enumrable(hierarchyArray,function(e,progress){
            prg.up();
            query+=e.GetQuery(IsSchema);
        });

        max=ext.count(viewArray);
        query +="--" +max+ ".create view"+CR;
        query +=CreateView();
        query +=suffix;
        NewPage(query);
        return query;
    }
    //エンティティ配列名からクエリ生成
    function CreateEntityFromNames(names,dropFlg){
        if(names.length==0)return "";
        var query="-- create tables "+names.length;
        for(var index in names){
            query+=CreateEntityQuery(names[index],dropFlg);
        }
        NewPage(query);
        return query;
    }
    //エンティティ名からクエリ生成
    function CreateEntityFromName(name,dropFlg){
        var entity=ext.toFirst(entityArray,function(e){return e.Name==name;});
        if(entity==null)return "";
        var query=CreateEntityQuery(name,dropFlg);
        NewPage(query);
        return query;
    }
    //消去のみのクエリ生成
    function CreateAllDrop(){
        var query="-caution!! all table recodes delete.-"+CR;
        for(var index in entityArray){
            if(entityArray[index].IsTrigger != null)
                query+=entityArray[index].IsTrigger.GetDropQuery(IsSchema)+CR;
        }
        for(var index in entityArray){
            query+=entityArray[index].GetDropQuery(IsSchema)+CR;
        }
        NewPage(query);
        return query;
    }
    //エンティティ名から消去クエリ生成
    function CreateDropFromName(name){
        var entity=ext.toFirst(entityArray,function(e){return e.Name==name;});
        if(entity==null)return "";
        var query="";
        query+=entity.GetDropQuery(IsSchema);
        query+=entity.IsTrigger.GetDropQuery(IsSchema)+CR;
        NewPage(query);
        return query;
    }
    //ビュー生成
    function CreateView(){
        var query="";
        var views=ext.toWhere(entityArray,function(e){return e.IsView;});
        for(var index in views){
            query+=views[index].GetQuery(IsSchema);
        }
        return query;
    }
    //タブページ追加
    function NewPage(query){
        //println(query);
        var editer=application.newSqlEditor(query);
    }
    //名前からエンティティクエリ生成
    function CreateEntityQuery(name,dropFlg){
        var entity=ext.toFirst(entityArray,function(e){return e.Name==name;});
        if(entity==null)return "";
        var query="";

        query+="-- create "+ entity.Name;
        if(dropFlg)query+=entity.GetDropQuery(IsSchema);
        if(entity.IsView){
            query+=" view"+CR;
        }else{
            query+=" table"+CR;
        }
        if(dropFlg)query+=entity.GetDropQuery(IsSchema);
        query+=entity.GetQuery(IsSchema);
        
        if(!entity.IsView){
            query+=entity.GetCommentQuery(IsSchema)+CR;
            query+=entity.GetPkQuery(IsSchema)+CR;
            query+=entity.GetUniqueQuery(IsSchema)+CR;
            query+=entity.GetFkQuery(IsSchema,entityArray)+CR;
            if(entity.IsTrigger!=null){
                query+=entity.IsTrigger.GetDropQuery(IsSchema)+CR;
                query+=entity.GetTriggerQuery(IsSchema,entityArray)+CR;
            }
            
        }
        var hierarchy=ext.toFirst(hierarchyArray,function(e,progress){
            return e.RelEntity.pName==name;
        });
        if(hierarchy!=null){
            query+=hierarchy.GetQuery(IsSchema);
        }
        return query;
    }
}

var selectEntities=new Array;
var mng =(function(){
    var result=application.getActiveWindow();
    if (result.formType != "A5EREditor") {
        alert("アクティブウィンドウをERエディタにしてから実行してください。");
        exit();
    }

    selectEntities=ext.toSelect(ext.toWhere(result.document.selectedObjects,function(e)
        {
            return e.objectType=="Entity";
        }),function(e){return e.pName;});

    commonAttrs=result.document.commonAttributes;
    domainArray=result.document.domains;
    return new GeneratManager(result.document,SCHEMA);
})();

